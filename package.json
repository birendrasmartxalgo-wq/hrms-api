{
  "name": "@hrms/api",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "docs:capture": "bun scripts/capture-api-responses.ts",
    "docs:filter": "bun scripts/filter-success-responses.ts",
    "seed:empty-routes": "bun --env-file=.env scripts/seed-empty-routes.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1045.0",
    "@aws-sdk/lib-storage": "3.1045.0",
    "@aws-sdk/s3-request-presigner": "3.1045.0",
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/cron": "1.4.2",
    "@elysiajs/jwt": "1.4.2",
    "@elysiajs/swagger": "1.3.1",
    "@sinclair/typebox": "^0.34.0",
    "bcryptjs": "3.0.3",
    "elysia": "1.4.28",
    "mongodb": "7.2.0",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "mongodb-memory-server": "^11.1.0",
    "typescript": "^6.0.3"
  }
}
