# apps/api environment — copy to apps/api/.env or repo-root .env (Bun auto-loads both)
# Required from Phase 1:
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Optional with defaults:
# API_PORT=6000
# API_VERSION=v1
# NODE_ENV=development
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Required from Phase 2 onward (MongoDB):
# MONGO_URI=mongodb://localhost:27017/hrms

# Required from Phase 4 onward (S3-compatible storage):
# S3_BUCKET=hrms
# S3_REGION=auto
# R2_ACCOUNT_ID=             # Cloudflare R2 shortcut for S3_ENDPOINT
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=               # optional, e.g. https://<account-id>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=       # optional bool ("true"/"false"), for LocalStack/MinIO

# Required from Phase 7 onward (Geofence — falls back to defaults if unset):
# OFFICE_LAT=
# OFFICE_LNG=
# OFFICE_RADIUS_M=

# Required from Phase 8 onward (Email):
# SES_FROM=no-reply@smartxalgo.com
